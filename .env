# =============================================================================
# IBKR Trading Bot - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All TRADING_BOT_ prefixed vars override config.yaml settings.
# Nested config uses double underscore (__) as delimiter.
# =============================================================================

# -----------------------------------------------------------------------------
# IBKR Connection
# -----------------------------------------------------------------------------
TRADING_BOT_CONNECTION__HOST=127.0.0.1
TRADING_BOT_CONNECTION__PORT=4002
TRADING_BOT_CONNECTION__CLIENT_ID=1
TRADING_BOT_CONNECTION__MODE=tws

# -----------------------------------------------------------------------------
# Database (PostgreSQL with async driver)
# -----------------------------------------------------------------------------
TRADING_BOT_DATABASE__URL=postgresql+asyncpg://bot:bot@localhost:5432/trading

# -----------------------------------------------------------------------------
# Redis (cache + pub/sub)
# -----------------------------------------------------------------------------
TRADING_BOT_REDIS__URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Dashboard
# -----------------------------------------------------------------------------
TRADING_BOT_DASHBOARD__PORT=8080
TRADING_BOT_DASHBOARD__AUTH_TOKEN=my-secret-trading-token-2026

# -----------------------------------------------------------------------------
# Alerts - Slack
# -----------------------------------------------------------------------------
TRADING_BOT_ALERTS__SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Alerts - Email (SMTP)
# -----------------------------------------------------------------------------
TRADING_BOT_ALERTS__SMTP_HOST=smtp.gmail.com
TRADING_BOT_ALERTS__SMTP_PORT=587
TRADING_BOT_ALERTS__SMTP_USER=binaryerrol@gmail.com
TRADING_BOT_ALERTS__SMTP_PASSWORD=kydt mddo beiz ycpz
TRADING_BOT_ALERTS__FROM_EMAIL=binaryerrol@gmail.com

# -----------------------------------------------------------------------------
# Alerts - Webhook (generic HTTP POST)
# -----------------------------------------------------------------------------
TRADING_BOT_ALERTS__WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
TRADING_BOT_LOG_LEVEL=INFO
TRADING_BOT_LOG_FILE=logs/trading_bot.log

# -----------------------------------------------------------------------------
# Docker Compose (used in docker-compose.yml port mapping)
# -----------------------------------------------------------------------------
DASHBOARD_PORT=8080
